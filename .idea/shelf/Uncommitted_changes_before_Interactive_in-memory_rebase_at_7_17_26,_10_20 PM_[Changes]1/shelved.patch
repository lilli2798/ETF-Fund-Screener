-def fetch_fund_data_for_chunk(tickers: List[str], sleep_between_tickers: float) -> List[Dict]:
-    results = []
-    for ticker in tickers:
-        data = fetch_fund_data_for_ticker(ticker)
-        if data is not None:
-            results.append(data)
-        if sleep_between_tickers > 0:
-            time.sleep(sleep_between_tickers)
-    return results
