-def fetch_all_fund_data(
-    tickers: List[str],
-    chunk_size: int = DEFAULT_CHUNK_SIZE,
-    sleep_between_chunks: float = DEFAULT_SLEEP_BETWEEN_CHUNKS,
-    sleep_between_tickers: float = DEFAULT_SLEEP_BETWEEN_TICKERS,
-) -> List[Dict]:
-    chunks = chunk_list(tickers, chunk_size)
-    all_results: List[Dict] = []
-    for i, chunk in enumerate(chunks, start=1):
-        print(f"Fetching chunk {i}/{len(chunks)} ({len(chunk)} tickers)...")
