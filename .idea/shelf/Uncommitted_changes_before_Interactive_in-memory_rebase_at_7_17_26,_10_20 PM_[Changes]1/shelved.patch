-    return eligible
-
-
-# ---------------------------------------------------------------------------
-# 7. COMPOSITE SCORE + RANKING
-# ---------------------------------------------------------------------------
-def compute_profile_A_score(df: pd.DataFrame, top_n_per_category: int) -> pd.DataFrame:
