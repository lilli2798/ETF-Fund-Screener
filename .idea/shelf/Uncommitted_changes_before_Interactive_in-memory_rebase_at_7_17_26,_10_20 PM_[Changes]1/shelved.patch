+import logging.config
+import os
+import sys
+import pandas as pd
+
+ROOT_DIR = os.path.realpath(os.path.join(os.path.dirname(__file__), '..'))
+
+
+def out_put_dir(new_file):
+    try:
+        os.makedirs(os.path.dirname(new_file))
+    except FileNotFoundError as e:
+        print(f"File error: {e}")
+
+
+# Used by morning_utils.py
+# update existing workbook and create a new sheet
+def update_result_book_with_create_new(fund_data, result_file, sheet_name):
+    # Check if the Excel file exists
+    try:
+        if os.path.exists(result_file):
+            # If the file exists, open it and add a new sheet
+            excel_writer = pd.ExcelWriter(result_file, engine='openpyxl', mode='a')
+            fund_data.to_excel(excel_writer, index=True, sheet_name=sheet_name)
+        else:
+            out_put_dir(result_file)
+            # If the file doesn't exist, create a new Excel file and add a sheet
+            excel_writer = pd.ExcelWriter(result_file, engine='openpyxl')
+            fund_data.to_excel(excel_writer, index=True, sheet_name=sheet_name)
+        excel_writer.close()
+    except Exception as e:
+        print('Exception in update_result_book_with_create_new for ' + result_file + ' and sheet name is ' + sheet_name)
+        print(e)
