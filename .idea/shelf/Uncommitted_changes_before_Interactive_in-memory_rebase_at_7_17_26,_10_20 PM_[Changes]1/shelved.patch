-def fetch_fund_data_for_ticker(ticker: str) -> Optional[Dict]:
-    """
-    Fetch sector_weightings and top_holdings for a single ETF ticker.
-    Returns None (and prints a warning) if the ticker has no fund data
-    (e.g. it's not actually an ETF/fund, or Yahoo has no data for it).
-    """
-    try:
-        t = yf.Ticker(ticker)
-        fd = t.funds_data
-        if fd is None:
-            print(f"  [warn] {ticker}: no funds_data available (not a fund, or unlisted).")
-            return None
-
-        sector_weightings = fd.sector_weightings or {}
-        top_holdings_df = fd.top_holdings  # DataFrame indexed by symbol, column 'Holding Percent' (varies by version)
-
-        if top_holdings_df is None or top_holdings_df.empty:
-            print(f"  [warn] {ticker}: no top_holdings data.")
-            top_holdings_df = pd.DataFrame()
-
-        return {
-            "ticker": ticker,
-            "sector_weightings": sector_weightings,
-            "top_holdings": top_holdings_df,
-        }
-    except Exception as exc:
-        print(f"  [error] {ticker}: {exc}")
-        return None
