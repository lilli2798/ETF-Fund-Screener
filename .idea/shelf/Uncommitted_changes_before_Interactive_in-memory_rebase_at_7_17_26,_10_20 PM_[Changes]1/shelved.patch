-def fetch_industry_lookup(
-    symbols: List[str],
-    chunk_size: int = DEFAULT_CHUNK_SIZE,
-    sleep_between_chunks: float = DEFAULT_SLEEP_BETWEEN_CHUNKS,
-) -> Dict[str, Dict[str, str]]:
-    """
-    For each underlying stock symbol, look up its 'sector' and
-    'industry' fields (finer-grained than sector, e.g. 'Semiconductors'
-    vs 'Software - Infrastructure'). Uses yf.Tickers batch object,
-    still chunked to respect the same pacing as the fund-level pulls.
-    """
-    chunks = chunk_list(symbols, chunk_size)
-    lookup: Dict[str, Dict[str, str]] = {}
-    for i, chunk in enumerate(chunks, start=1):
-        print(f"Looking up industry for chunk {i}/{len(chunks)} ({len(chunk)} symbols)...")
-        tickers_obj = yf.Tickers(" ".join(chunk))
-        for symbol in chunk:
-            try:
-                info = tickers_obj.tickers[symbol].info
-                lookup[symbol] = {
-                    "sector": info.get("sector", ""),
-                    "industry": info.get("industry", ""),
-                }
-            except Exception as exc:
-                print(f"  [warn] industry lookup failed for {symbol}: {exc}")
-                lookup[symbol] = {"sector": "", "industry": ""}
-        if i < len(chunks) and sleep_between_chunks > 0:
-            time.sleep(sleep_between_chunks)
-    return lookup
