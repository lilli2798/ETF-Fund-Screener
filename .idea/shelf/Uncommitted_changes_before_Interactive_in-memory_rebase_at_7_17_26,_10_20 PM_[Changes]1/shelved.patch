--- /dev/null	(date 1784253307426)
+++ b/yahoo_utils/yahoo_dta.py	(date 1784253307426)
@@ -0,0 +1,40 @@
+import numpy as np
+import pandas as pd
+import yfinance as yf
+
+tickers = ["TYLG", "SPY", "QQQ", "SMH", "JEPI", "XLV"]
+
+print("Downloading clean daily historical data...")
+# 1. Download DAILY data (Guarantees 'Adj Close' is present and fully populated)
+daily_adj_close = yf.download(tickers, period="1y", interval="1d", auto_adjust=False)["Adj Close"]
+
+# 2. Extract Adj Close safely
+#
+
+# 3. CONVERT TO MONTHLY: Grab the last trading day of each calendar month
+# This mimics 'interval="1mo"' perfectly but avoids Yahoo's API bugs
+data = daily_adj_close.resample("ME").last()
+
+# 4. Proceed with your returns calculation as normal
+monthly_returns = data.pct_change().dropna()
+
+# --- Everything below this stays exactly the same as your Sharpe Ratio loop ---
+risk_free_monthly = 0.04 / 12
+sharpe_results = {}
+
+for ticker in tickers:
+    if ticker in monthly_returns.columns:
+        excess_returns = monthly_returns[ticker] - risk_free_monthly
+        mean_excess = excess_returns.mean()
+        std_excess = excess_returns.std()
+
+        if std_excess > 0:
+            annualized_sharpe = (mean_excess / std_excess) * np.sqrt(12)
+        else:
+            annualized_sharpe = np.nan
+        sharpe_results[ticker] = annualized_sharpe
+
+df_sharpe = pd.DataFrame(
+    list(sharpe_results.items()), columns=["Ticker", "Sharpe_Ratio_1Y"]
+)
+print(df_sharpe.sort_values(by="Sharpe_Ratio_1Y", ascending=False))
